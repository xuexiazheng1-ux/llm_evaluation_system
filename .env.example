# OpenAI / LLM Configuration for Docker Compose
# 用于评测评分的LLM API密钥（支持OpenAI、DeepSeek等）
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# LLM Provider Configuration
# 支持的类型: openai, deepseek, claude, custom
LLM_PROVIDER_TYPE=openai
LLM_PROVIDER_MODEL=gpt-3.5-turbo

# 自定义提供商配置（当 LLM_PROVIDER_TYPE=custom 时使用）
# LLM_CUSTOM_PAYLOAD_TEMPLATE={"model":"{model}","messages":[{"role":"user","content":"{input}"}]}
# LLM_CUSTOM_OUTPUT_PATH=choices.0.message.content
# LLM_CUSTOM_HEADERS={"Authorization":"Bearer {api_key}"}

# Target Agent Configuration
# 待评测系统的API地址（如AnythingLLM）
TARGET_URL=http://your-agent-api.com/chat
TARGET_API_KEY=your-target-api-key

# Database Configuration
DATABASE_URL=postgresql+asyncpg://llm_eval:password@postgres:5432/llm_eval

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Celery Configuration
CELERY_WORKER_CONCURRENCY=4

# Evaluation Configuration
EVAL_TIMEOUT=30
